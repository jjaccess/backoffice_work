# ============================================================
#  Variables de entorno — Backend Visitas
#  Copiar como .env y ajustar valores
# ============================================================

# Servidor
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=visitas_db
DB_USER=visitas_app
DB_PASSWORD=2222222
DB_MAX_CONNECTIONS=10
DB_IDLE_TIMEOUT_MS=30000

# JWT
JWT_SECRET=miSecretoMuyLargo123456789ABCDEFabcdef
JWT_EXPIRES_IN=8h

# CORS — orígenes permitidos (separados por coma)
CORS_ORIGINS=http://localhost:4200,http://localhost:3001

# Logs
LOG_LEVEL=info
